<Window x:Class="Sistema_de_Monitoreo_Industrial.Views.ConfirmDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Confirmación" Height="200" Width="380"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterOwner" ShowInTaskbar="False" ResizeMode="NoResize">

    <Border Background="#1E1E1E" CornerRadius="12" BorderBrush="{StaticResource OrangeAccent}" BorderThickness="1.5">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <TextBlock x:Name="txtMensaje" 
                       Text="¿Deseas realizar esta acción?" 
                       Foreground="White" FontSize="13" 
                       TextWrapping="Wrap" 
                       HorizontalAlignment="Center" 
                       VerticalAlignment="Center" 
                       TextAlignment="Center"
                       LineHeight="18"/>

            <StackPanel Grid.Row="1" Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                <Button x:Name="btnAceptar" 
                        Content="SÍ, PROCEDER" 
                        Click="BtnSi_Click" 
                        Width="120" Height="32" 
                        Style="{StaticResource BtnPlay}" 
                        FontWeight="Bold" 
                        Margin="0,0,10,0"/>

                <Button x:Name="btnCancelar" 
                        Content="CANCELAR" 
                        Click="BtnNo_Click" 
                        Width="120" Height="32" 
                        Background="#333" 
                        Foreground="White" 
                        Margin="10,0,0,0">
                    <Button.Style>
                        <Style TargetType="Button">
                            <Setter Property="Template">
                                <Setter.Value>
                                    <ControlTemplate TargetType="Button">
                                        <Border Background="{TemplateBinding Background}" CornerRadius="5">
                                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>
                                    </ControlTemplate>
                                </Setter.Value>
                            </Setter>
                            <Style.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter Property="Background" Value="#444"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                </Button>
            </StackPanel>
        </Grid>
    </Border>
</Window>
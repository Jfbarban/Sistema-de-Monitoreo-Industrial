<Window x:Class="Sistema_de_Monitoreo_Industrial.Views.LoginWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Acceso al Sistema" Height="450" Width="400"
        WindowStyle="None" AllowsTransparency="True" Background="Transparent"
        WindowStartupLocation="CenterScreen" MouseDown="Window_MouseDown" Icon="/Resources/Icono.ico" ShowInTaskbar="False">

    <Border Background="#1E1E1E" CornerRadius="20" BorderBrush="#333" BorderThickness="1.5">
        <StackPanel Margin="40">
            <TextBlock Text="SISTEMA DE MONITOREO" 
                       Foreground="{StaticResource OrangeAccent}" 
                       FontSize="18" FontWeight="Bold" 
                       HorizontalAlignment="Center" Margin="0,0,0,40"/>

            <TextBlock Text="USUARIO" Foreground="Gray" FontSize="10" 
                       FontWeight="Bold" Margin="0,0,0,8"/>
            
            <TextBox x:Name="txtUser" Height="40" Margin="0,0,0,20" 
                     Style="{StaticResource ModernTextBoxStyle}"
                     VerticalContentAlignment="Center" Padding="10,0"/>

            <TextBlock Text="CONTRASEÑA" Foreground="Gray" FontSize="10" 
                       FontWeight="Bold" Margin="0,0,0,8"/>

            <Grid Height="40" Margin="0,0,0,30">
                <PasswordBox x:Name="txtPass" 
                     Style="{StaticResource ModernPasswordBoxStyle}"
                     VerticalContentAlignment="Center"/>

                <TextBox x:Name="txtPassVisible" 
                     Style="{StaticResource ModernTextBoxStyle}" 
                     Visibility="Collapsed"
                     VerticalContentAlignment="Center"/>

                <Button x:Name="btnPassVisibility" HorizontalAlignment="Right" Content="👁" Background="Transparent" Style="{StaticResource BtnConfigStyle}" Foreground="{StaticResource TextDim}" FontSize="20" Margin="0,0,5,0" Cursor="Hand" Click="btnChecked"/>
            </Grid>

            <Button x:Name="btnLogin" Content="INICIAR SESIÓN" Height="45" Style="{StaticResource BtnPlay}"
                    FontSize="15" Click="BtnLogin_Click" />


            <ToggleButton Content="SALIR" Margin="0,15,0,0" FontSize="15" Foreground="{StaticResource OrangeAccent}" 
                    Style="{StaticResource BtnSaveHistorial}" Cursor="Hand" Click="BtnExit_Click" Height="41"/>
        </StackPanel>
    </Border>
</Window>
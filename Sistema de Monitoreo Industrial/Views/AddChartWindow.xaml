<Window x:Class="Sistema_de_Monitoreo_Industrial.Views.AddChartWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Configurar Widget | Vertex-IoT" Height="500" Width="400" 
        Background="Transparent" WindowStartupLocation="CenterOwner"
        WindowStyle="None" AllowsTransparency="True">

    <Border BorderBrush="#333" BorderThickness="1.5" CornerRadius="15" Background="#1E1E1E">
        <Grid Margin="25">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <StackPanel Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="CONFIGURAR NUEVA GRÁFICA" Foreground="White" FontSize="16" FontWeight="Black"/>
                <Rectangle Height="2" Fill="{StaticResource OrangeAccent}" HorizontalAlignment="Left" Width="40" Margin="0,5,0,0"/>
            </StackPanel>

            <StackPanel Grid.Row="1">
                <Label Content="Título del Widget" Foreground="Gray" FontSize="11" FontWeight="Bold"/>
                <TextBox x:Name="TxtTitle" Text="Monitoreo en Tiempo Real" 
                         Style="{StaticResource ModernTextBoxStyle}" Margin="0,5,0,15"/>

                <Label Content="Tipo de Visualización" Foreground="Gray" FontSize="11" FontWeight="Bold"/>
                <ComboBox x:Name="CmbType" Margin="0,5,0,15" Height="35"
                          DisplayMemberPath="Nombre" SelectedValuePath="Tag"
                          SelectionChanged="CmbType_SelectionChanged" Style="{StaticResource ModernComboBox}"/>

                <Label Content="Nodo / Robot de Origen" Foreground="Gray" FontSize="11" FontWeight="Bold"/>
                <ComboBox x:Name="CmbRobot" Margin="0,5,0,20" Height="35"
          DisplayMemberPath="." Style="{StaticResource ModernComboBox}" SelectionChanged="CmbRobot_SelectionChanged"/>

                <Label Content="Variable (Métrica InfluxDB)" Foreground="Gray" FontSize="11" FontWeight="Bold"/>
                <ComboBox x:Name="CmbProp" Margin="0,5,0,15" Height="35"
                          DisplayMemberPath="Nombre" SelectedValuePath="Tag" Style="{StaticResource ModernComboBox}"/>
                
            </StackPanel>

            <Grid Grid.Row="2">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <Button Content="CANCELAR" Click="BtnCancelar_Click" Width="100" Height="40" 
                        Style="{StaticResource BtnDark}" Margin="0,0,10,0"/>

                <Button Grid.Column="1" Content="AÑADIR AL DASHBOARD" Click="BtnAdd_Click" 
                        Height="40" Style="{StaticResource BtnPlay}" FontWeight="Bold"/>
            </Grid>
        </Grid>
    </Border>
</Window>
<Window x:Class="Sistema_de_Monitoreo_Industrial.Views.ChangePasswordWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Seguridad - Vertex IoT" Height="457" Width="350" SizeToContent="Height"
        Background="Transparent" WindowStartupLocation="CenterOwner" ResizeMode="NoResize" WindowStyle="None">

    <Border Background="#1E1E1E" CornerRadius="20" Padding="15" BorderBrush="#333" BorderThickness="1.5">
        <StackPanel>
            <TextBlock Text="ACTUALIZAR CONTRASEÑA" Foreground="{StaticResource OrangeAccent}" 
                       FontSize="16" FontWeight="Black" Margin="0,0,0,25"/>

            <TextBlock Text="NUEVA CONTRASEÑA" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,0,0,5"/>

            <Grid Height="40" Margin="0,0,0,30">
                <PasswordBox x:Name="txtPass1" 
                     Style="{StaticResource ModernPasswordBoxStyle}"
                     VerticalContentAlignment="Center" PasswordChanged="Password_PasswordChanged"/>

                <TextBox x:Name="txtPass1Visible" 
                     Style="{StaticResource ModernTextBoxStyle}" 
                     Visibility="Collapsed"
                     VerticalContentAlignment="Center"/>

                <Button x:Name="btnPass1Visibility" HorizontalAlignment="Right" Content="👁" Background="Transparent" Style="{StaticResource BtnConfigStyle}" Foreground="{StaticResource TextDim}" FontSize="20" Margin="0,0,5,0" Cursor="Hand" Click="btn1Checked"/>
            </Grid>

            <TextBlock x:Name="txtValidaLongitud" Text="⚠ Mínimo 4 caracteres" 
           Foreground="#FF4444" FontSize="10" Margin="0,5,0,0" Visibility="Collapsed"/>

            <TextBlock Text="CONFIRMAR CONTRASEÑA" Foreground="Gray" FontSize="10" FontWeight="Bold" Margin="0,15,0,5"/>

            <Grid Height="40" Margin="0,0,0,30">
                <PasswordBox x:Name="txtPass2" 
                     Style="{StaticResource ModernPasswordBoxStyle}"
                     VerticalContentAlignment="Center" PasswordChanged="Password_PasswordChanged"/>

                <TextBox x:Name="txtPass2Visible" 
                     Style="{StaticResource ModernTextBoxStyle}" 
                     Visibility="Collapsed"
                     VerticalContentAlignment="Center"/>

                <Button x:Name="btnPass2Visibility" HorizontalAlignment="Right" Content="👁" Background="Transparent" Style="{StaticResource BtnConfigStyle}" Foreground="{StaticResource TextDim}" FontSize="20" Margin="0,0,5,0" Cursor="Hand" Click="btn2Checked"/>
            </Grid>

            <TextBlock x:Name="txtValidaCoincidencia" Text="Las contraseñas deben coincidir" 
                       Foreground="#FF4444" FontSize="10" Margin="0,10,0,0" 
                       HorizontalAlignment="Center" Visibility="Collapsed"/>

            <Button x:Name="btnGuardar" Content="GUARDAR CAMBIOS" Height="45" Margin="0,30,0,0"
                    Style="{StaticResource BtnPlay}" IsEnabled="False" Click="BtnGuardar_Click"/>

            <ToggleButton Content="CANCELAR" Margin="0,15,0,0" FontSize="15" Foreground="{StaticResource OrangeAccent}" 
        Style="{StaticResource BtnSaveHistorial}" Cursor="Hand" Click="BtnCancelar_Click" Height="41"/>
        </StackPanel>
    </Border>
</Window>
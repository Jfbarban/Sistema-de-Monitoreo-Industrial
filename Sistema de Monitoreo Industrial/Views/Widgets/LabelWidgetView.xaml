<UserControl x:Class="Sistema_de_Monitoreo_Industrial.Views.Widgets.LabelWidgetView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
             xmlns:vm="clr-namespace:Sistema_de_Monitoreo_Industrial.ViewModels.Widgets"
             mc:Ignorable="d" d:DesignHeight="150" d:DesignWidth="250"
             d:DataContext="{d:DesignInstance Type=vm:LabelWidgetViewModel, IsDesignTimeCreatable=True}">

    <UserControl.Resources>
        <Storyboard x:Key="OnValueChange">
            <DoubleAnimation Storyboard.TargetName="ContentGrid" 
                             Storyboard.TargetProperty="Opacity"
                             From="0.4" To="1.0" Duration="0:0:0.4"/>
        </Storyboard>

        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontSize" Value="16"/>
            <Setter Property="Opacity" Value="0.6"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Opacity" Value="1"/>
                    <Setter Property="Foreground" Value="#E74C3C"/>
                </Trigger>
            </Style.Triggers>
        </Style>
    </UserControl.Resources>

    <Border Background="{Binding BackgroundBrush}" 
            CornerRadius="10" 
            Margin="5" 
            BorderBrush="White" 
            BorderThickness="0,0,0,0">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="2" Opacity="0.2"/>
        </Border.Effect>

        <Grid x:Name="ContentGrid" >
            <StackPanel VerticalAlignment="Center">
                <TextBlock Text="{Binding Title}" 
                           Foreground="White" 
                           FontWeight="SemiBold"
                           Opacity="0.8" 
                           HorizontalAlignment="Center" 
                           FontSize="12"/>

                <TextBlock Text="{Binding DisplayText}" 
                           Foreground="White" 
                           FontSize="24" 
                           FontWeight="Bold" 
                           HorizontalAlignment="Center" 
                           Margin="0,8"
                           TextWrapping="Wrap"/>

                <TextBlock Text="{Binding RobotId}" 
                           Foreground="White" 
                           FontSize="10" 
                           Opacity="0.5" 
                           HorizontalAlignment="Center"
                           FontStyle="Italic"/>
            </StackPanel>

            <Button Command="{Binding RemoveCommand}" 
                    Content="✕" 
                    Style="{StaticResource CloseButtonStyle}"
                    HorizontalAlignment="Right" 
                    VerticalAlignment="Top"
                    Cursor="Hand"
                    Width="24" Height="24"/>
        </Grid>
    </Border>
</UserControl>
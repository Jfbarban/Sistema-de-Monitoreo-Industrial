<Window x:Class="Sistema_de_Monitoreo_Industrial.Views.UserManagementWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Gestión de Usuarios" Height="500" Width="700"
        Background="Transparent" AllowsTransparency="True" WindowStartupLocation="CenterOwner" WindowStyle="None">

    <Border Background="#1E1E1E" CornerRadius="20" BorderBrush="#333" BorderThickness="1.5">
        <Grid Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Margin="0,0,0,20">
                <TextBlock Text="GESTIÓN DE PERSONAL" Foreground="{StaticResource OrangeAccent}" 
       FontSize="20" FontWeight="Black"/>

                <ToggleButton x:Name="btnCerrar" Width="100" HorizontalAlignment="Right" Content="Cerrar" Background="Transparent" Style="{StaticResource BtnSaveHistorial}" Foreground="{StaticResource TextDim}" FontSize="20" Margin="0,0,5,0" Cursor="Hand" Click="btnCerrar_Click"/>
            </Grid>

            <DataGrid x:Name="dgUsuarios" Grid.Row="1" AutoGenerateColumns="False" 
              Background="#181818" BorderBrush="#333" Foreground="White"
              RowBackground="#181818" AlternatingRowBackground="#202020"
              CanUserAddRows="False" GridLinesVisibility="None" IsReadOnly="True" Style="{StaticResource IndustrialDataGrid}" HeadersVisibility="Column">

                <DataGrid.Columns>
                    <DataGridTextColumn Header="NOMBRE DE USUARIO" Binding="{Binding Username}" Width="*"/>
                    <DataGridTextColumn Header="ROL DE ACCESO" Binding="{Binding Role}" Width="150"/>

                    <DataGridTemplateColumn Header="ACCIONES" Width="120">
                        <DataGridTemplateColumn.CellTemplate>
                            <DataTemplate>
                                <ToggleButton Content="ELIMINAR" 
                                Command="{Binding DataContext.EliminarCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Style="{StaticResource BtnSaveHistorial}" Background="Transparent" Foreground="#FF4444" Cursor="Hand" FontWeight="Bold" Height="25"/>
                            </DataTemplate>
                        </DataGridTemplateColumn.CellTemplate>
                    </DataGridTemplateColumn>
                </DataGrid.Columns>
            </DataGrid>

            <Button Grid.Row="2" Content="+ REGISTRAR NUEVO USUARIO" Height="45" Margin="0,20,0,0"
            Style="{StaticResource BtnPlay}" Click="BtnNuevoUsuario_Click"/>
        </Grid>
    </Border>
    
</Window>
<Window x:Class="Sistema_de_Monitoreo_Industrial.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:Sistema_de_Monitoreo_Industrial.ViewModels.Widgets"
        xmlns:views="clr-namespace:Sistema_de_Monitoreo_Industrial.Views.Widgets"
        mc:Ignorable="d"
        Title="Vertex-IoT | Control Panel" Height="533" Width="1264" MinHeight="533" MinWidth="1264" 
        Background="{StaticResource FondoOscuro}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>

        <Style x:Key="SilenceButtonStyle" TargetType="Button">
            <Setter Property="Background" Value="#CCFF0000"/>
            <Setter Property="Foreground" Value="White"/>
            <Setter Property="FontWeight" Value="Bold"/>
            <Setter Property="Padding" Value="10,5"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="Visibility" Value="Collapsed"/>
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}" CornerRadius="4">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAlerting}" Value="True">
                    <Setter Property="Visibility" Value="Visible"/>
                </DataTrigger>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="Red"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="WidgetCardStyle" TargetType="Border" BasedOn="{StaticResource CardStyle}">
            <Setter Property="Margin" Value="10"/>
            <Setter Property="Padding" Value="0"/>
            <Setter Property="BorderBrush" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="2"/>
            <Setter Property="Effect">
                <Setter.Value>
                    <DropShadowEffect BlurRadius="15" Direction="270" RenderingBias="Quality" ShadowDepth="2" Opacity="0.3"/>
                </Setter.Value>
            </Setter>

            <Style.Triggers>
                <DataTrigger Binding="{Binding IsAlerting}" Value="True">
                    <DataTrigger.EnterActions>
                        <BeginStoryboard x:Name="BlinkAnim">
                            <Storyboard>
                                <ColorAnimation Storyboard.TargetProperty="(Border.BorderBrush).(SolidColorBrush.Color)"
                                                From="Red" To="Transparent" 
                                                Duration="0:0:0.5" 
                                                AutoReverse="True" 
                                                RepeatBehavior="Forever"/>
                                <ThicknessAnimation Storyboard.TargetProperty="BorderThickness"
                                                    To="4" Duration="0:0:0.0"/>
                            </Storyboard>
                        </BeginStoryboard>
                    </DataTrigger.EnterActions>
                    <DataTrigger.ExitActions>
                        <StopStoryboard BeginStoryboardName="BlinkAnim"/>
                    </DataTrigger.ExitActions>
                </DataTrigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="VerticalSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="HorizontalAlignment" Value="Stretch"/>
            <Setter Property="VerticalAlignment" Value="Center"/>
            <Setter Property="Height" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource OrangeAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <Style x:Key="ColumnSplitterStyle" TargetType="GridSplitter">
            <Setter Property="Background" Value="#252525"/>
            <Setter Property="HorizontalAlignment" Value="Center"/>
            <Setter Property="VerticalAlignment" Value="Stretch"/>
            <Setter Property="Width" Value="5"/>
            <Style.Triggers>
                <Trigger Property="IsMouseOver" Value="True">
                    <Setter Property="Background" Value="{StaticResource OrangeAccent}"/>
                </Trigger>
            </Style.Triggers>
        </Style>

        <DataTemplate DataType="{x:Type vm:WidgetGaugeViewModel}">
            <Border Style="{StaticResource WidgetCardStyle}" Width="260" Height="280">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#252525" CornerRadius="12,12,0,0">
                        <DockPanel Margin="15,0">
                            <TextBlock Text="{Binding Title}" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                            <Button Content="" Style="{StaticResource BtnDark}" FontFamily="Segoe MDL2 Assets" 
                                    Command="{Binding RemoveCommand}" DockPanel.Dock="Right" Width="30" Height="25" Foreground="#FF4444"/>
                        </DockPanel>
                    </Border>

                    <views:GaugeWidgetView Grid.Row="1" Margin="10"/>

                    <Button Grid.Row="1" Content="SILENCIAR ALARMA" 
                            Command="{Binding SilenceCommand}"
                            Style="{StaticResource SilenceButtonStyle}"
                            HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:WidgetSignalViewModel}">
            <Border Style="{StaticResource WidgetCardStyle}" Width="540" Height="280">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#252525" CornerRadius="12,12,0,0">
                        <DockPanel Margin="15,0">
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="8" Height="8" Fill="{StaticResource OrangeAccent}" Margin="0,0,8,0"/>
                                <TextBlock Text="{Binding Title}" Foreground="{StaticResource OrangeAccent}" FontWeight="Bold" FontSize="11"/>
                            </StackPanel>
                            <Button Content="" Style="{StaticResource BtnDark}" FontFamily="Segoe MDL2 Assets" 
                                    Command="{Binding RemoveCommand}" DockPanel.Dock="Right" Width="30" Height="25" Foreground="#FF4444"/>
                        </DockPanel>
                    </Border>

                    <views:SignalWidgetView Grid.Row="1" Margin="10"/>

                    <Button Grid.Row="1" Content="⚠️ SILENCIAR ALARMA" 
                            Command="{Binding SilenceCommand}"
                            Style="{StaticResource SilenceButtonStyle}"
                            HorizontalAlignment="Right" VerticalAlignment="Top"
                            Margin="0,10,20,0"/>
                </Grid>
            </Border>
        </DataTemplate>

        <DataTemplate DataType="{x:Type vm:WidgetStatusViewModel}">
            <Border Style="{StaticResource WidgetCardStyle}" Width="540" Height="180">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="40"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <Border Background="#252525" CornerRadius="12,12,0,0">
                        <DockPanel Margin="15,0">
                            <TextBlock Text="{Binding Title}" Foreground="White" VerticalAlignment="Center" FontWeight="Bold" FontSize="11"/>
                            <Button Content="" Style="{StaticResource BtnDark}" FontFamily="Segoe MDL2 Assets" 
                                    Command="{Binding RemoveCommand}" DockPanel.Dock="Right" Width="30" Height="25" Foreground="#FF4444"/>
                        </DockPanel>
                    </Border>

                    <views:StatusWidgetView Grid.Row="1" Margin="10"/>

                    <Button Grid.Row="1" Content="SILENCIAR" 
                            Command="{Binding SilenceCommand}"
                            Style="{StaticResource SilenceButtonStyle}"
                            HorizontalAlignment="Center" VerticalAlignment="Bottom"
                            Margin="0,0,0,10"/>
                </Grid>
            </Border>
        </DataTemplate>
    </Window.Resources>

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="220" MinWidth="180" MaxWidth="400"/>
            <ColumnDefinition Width="4"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>

        <Border Grid.Column="0" Background="#121212" BorderBrush="#333" BorderThickness="0,0,1,0" Padding="15">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.Row="0">
                    <Button x:Name="btnGuardarLayout" Content="GUARDAR DASHBOARD" 
                    Style="{StaticResource BtnSave}" 
                    Margin="0,0,0,15" 
                    Height="35"
                    Click="BtnGuardarLayout_Click"/>

                    <TextBlock Text="DASHBOARDS GUARDADOS" 
                       Foreground="#555" 
                       FontSize="10" 
                       FontWeight="Bold" 
                       Margin="0,0,0,10" 
                       HorizontalAlignment="Center"/>
                </StackPanel>

                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="panelDashboardsSaved"/>
                </ScrollViewer>
            </Grid>
        </Border>

        <GridSplitter Grid.Column="1" 
              Style="{StaticResource ColumnSplitterStyle}"
              ResizeDirection="Columns" 
              ShowsPreview="False"
              Cursor="SizeWE"/>

        <Grid Grid.Column="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="75" MinHeight="75"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="120" MinHeight="80" MaxHeight="450"/>
            </Grid.RowDefinitions>

            <Border Grid.Row="0" Background="{StaticResource PanelGris}" BorderBrush="#333" BorderThickness="0,0,0,0">
                <Grid Margin="25,0">
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="SISTEMA DE MONITOREO INDUSTRIAL" Foreground="White" FontSize="18" FontWeight="Black"/>
                            <StackPanel Orientation="Horizontal" Margin="0,2,0,0">
                                <Ellipse x:Name="LedOnline" Width="10" Height="10" Fill="Red" Margin="0,0,10,0">
                                    <Ellipse.Style>
                                        <Style TargetType="Ellipse">
                                            <Style.Triggers>
                                                <EventTrigger RoutedEvent="Loaded">
                                                    <BeginStoryboard>
                                                        <Storyboard>
                                                            <DoubleAnimation Storyboard.TargetProperty="Opacity" From="1" To="0.2" Duration="0:0:1.5" AutoReverse="True" RepeatBehavior="Forever"/>
                                                        </Storyboard>
                                                    </BeginStoryboard>
                                                </EventTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Ellipse.Style>
                                </Ellipse>
                                <TextBlock x:Name="txtEstadoConexion" Text="SISTEMA OFFLINE | DESCONECTADO" Foreground="{StaticResource OrangeAccent}" FontSize="11" FontWeight="Bold"/>
                            </StackPanel>
                        </StackPanel>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="AUDITORÍA DE ALARMAS" 
                            Style="{StaticResource BtnDark}" 
                            Click="BtnVerHistorial_Click" 
                            Width="180" Margin="5"/>
                        
                        <ToggleButton x:Name="btnConectar" 
                                    Content="CONECTAR SISTEMA" 
                                    Style="{StaticResource BtnConnectStyle}" 
                                    Padding="20,0" Height="35" Width="180"
                                    Click="BtnConectar_Click"/>

                        <Rectangle Width="1" Fill="#333" Margin="15,5"/>

                        <Button x:Name="btnAddWidget"
                                    Content="+ AÑADIR A DASHBOARD" 
                                    Style="{StaticResource BtnPlay}" 
                                    Padding="25,0" Height="35" 
                                    IsEnabled="{Binding IsConnected}"
                                    Click="BtnAdd_Click" Width="145"/>

                        <Rectangle Width="1" Fill="#333" Margin="10,5"/>

                        <Button x:Name="btnConfig" Content="⚙" Background="Transparent" 
                                    Style="{StaticResource BtnConfigStyle}" Foreground="{StaticResource TextDim}" 
                                    FontSize="25" Margin="0,0,15,0" Cursor="Hand" Click="btnConfig_Click"/>
                    </StackPanel>
                </Grid>
            </Border>

            <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Background="#0F0F0F">
                <ItemsControl ItemsSource="{Binding Widgets}">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <WrapPanel Orientation="Horizontal" HorizontalAlignment="Left"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>
            </ScrollViewer>

            <GridSplitter Grid.Row="2" 
                          Style="{StaticResource VerticalSplitterStyle}"
                          ResizeDirection="Rows" 
                          ShowsPreview="False"/>

            <Border Grid.Row="3" Background="#151515" BorderBrush="#333" BorderThickness="0,1,0,0" Padding="20,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="421*"/>
                        <ColumnDefinition Width="84*"/>
                        <ColumnDefinition Width="655*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <DockPanel Margin="0,0,0,5" Grid.ColumnSpan="3">
                        <TextBlock Text="LOG DE COMUNICACIONES" Foreground="{StaticResource OrangeAccent}" FontSize="10" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                            <TextBlock Text="NODOS ACTIVOS: " Foreground="Gray" FontSize="10" VerticalAlignment="Center"/>
                            <TextBlock Text="{Binding Widgets.Count}" Foreground="White" FontSize="10" FontWeight="Bold" VerticalAlignment="Center" Margin="5,0,20,0"/>
                            <Button Content="LIMPIAR LOG" Style="{StaticResource BtnDark}" Height="18" Width="90" FontSize="8" Click="BtnLimpiarConsola_Click"/>
                        </StackPanel>
                    </DockPanel>
                    <RichTextBox x:Name="txtConsola" 
                         Grid.Row="1" Grid.ColumnSpan="3"
                         Background="Black" 
                         FontFamily="Consolas" 
                         FontSize="11"
                         BorderThickness="0" 
                         IsReadOnly="True" 
                         VerticalScrollBarVisibility="Auto">
                        <RichTextBox.Resources>
                            <Style TargetType="{x:Type Paragraph}">
                                <Setter Property="Margin" Value="0"/>
                            </Style>
                        </RichTextBox.Resources>
                        <FlowDocument PagePadding="8">
                            <Paragraph x:Name="logParagraph">
                            </Paragraph>
                        </FlowDocument>
                    </RichTextBox>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>